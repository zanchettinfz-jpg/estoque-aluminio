<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.ProdutoController" styleClass="app-root">
    <left>
        <VBox prefWidth="240" spacing="8" styleClass="sidebar">
            <Label text="Estoque Alumínio" styleClass="sidebar-title"/>
            <Label text="Cadastro mestre" styleClass="sidebar-subtitle"/>
            <Button text="Dashboard" onAction="#abrirDashboard" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Produtos" onAction="#abrirProdutos" maxWidth="Infinity" styleClass="nav-button-active"/>
            <Button text="Estoque" onAction="#abrirEstoque" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Sobras" onAction="#abrirSobras" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Movimentações" onAction="#abrirMovimentacoes" maxWidth="Infinity" styleClass="nav-button"/>
            <VBox VBox.vgrow="ALWAYS"/>
            <Button text="Sair" onAction="#sair" maxWidth="Infinity" styleClass="danger-button"/>
        </VBox>
    </left>
    <center>
        <VBox spacing="16" styleClass="content">
            <Label text="Produtos" styleClass="page-title"/>
            <TextField fx:id="buscaField" promptText="Busca rápida por código, descrição, localização, linha ou cor"/>
            <HBox spacing="16" VBox.vgrow="ALWAYS">
                <VBox spacing="10" prefWidth="390" styleClass="panel">
                    <Label text="Cadastro de perfil" styleClass="section-title"/>
                    <GridPane hgap="10" vgap="10">
                        <Label text="Código" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="codigoField" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Label text="Descrição" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                        <TextField fx:id="descricaoField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <Label text="Cor" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="corField" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <Label text="Linha" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                        <TextField fx:id="linhaField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                        <Label text="Tamanho" styleClass="field-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <TextField fx:id="tamanhoField" promptText="6.0" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                        <Label text="Quantidade" styleClass="field-label" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                        <TextField fx:id="quantidadeField" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                        <Label text="Unidade" styleClass="field-label" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                        <TextField fx:id="unidadeField" promptText="un, barra, m" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                        <Label text="Localização" styleClass="field-label" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
                        <TextField fx:id="localizacaoField" promptText="A-01-03" GridPane.rowIndex="7" GridPane.columnIndex="1"/>
                    </GridPane>
                    <Label text="Observações" styleClass="field-label"/>
                    <TextArea fx:id="observacoesArea" prefRowCount="4"/>
                    <HBox spacing="8">
                        <Button text="Salvar" onAction="#salvar" styleClass="primary-button" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button text="Limpar" onAction="#limpar" styleClass="secondary-button"/>
                        <Button text="Excluir" onAction="#excluir" styleClass="danger-button"/>
                    </HBox>
                </VBox>
                <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="panel">
                    <Label text="Consulta inteligente" styleClass="section-title"/>
                    <TableView fx:id="produtosTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="codigoColumn" text="Código" prefWidth="110"/>
                            <TableColumn fx:id="descricaoColumn" text="Descrição" prefWidth="220"/>
                            <TableColumn fx:id="corColumn" text="Cor" prefWidth="90"/>
                            <TableColumn fx:id="linhaColumn" text="Linha" prefWidth="120"/>
                            <TableColumn fx:id="tamanhoColumn" text="Tam." prefWidth="70"/>
                            <TableColumn fx:id="quantidadeColumn" text="Qtd." prefWidth="70"/>
                            <TableColumn fx:id="unidadeColumn" text="Un." prefWidth="70"/>
                            <TableColumn fx:id="localizacaoColumn" text="Local" prefWidth="110"/>
                        </columns>
                    </TableView>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
