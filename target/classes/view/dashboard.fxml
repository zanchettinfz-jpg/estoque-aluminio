<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.DashboardController" styleClass="app-root">
    <left>
        <VBox prefWidth="240" spacing="8" styleClass="sidebar">
            <Label text="Estoque Alumínio" styleClass="sidebar-title"/>
            <Label text="ERP Industrial" styleClass="sidebar-subtitle"/>
            <Button text="Dashboard" onAction="#abrirDashboard" maxWidth="Infinity" styleClass="nav-button-active"/>
            <Button text="Produtos" onAction="#abrirProdutos" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Estoque" onAction="#abrirEstoque" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Sobras" onAction="#abrirSobras" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Movimentações" onAction="#abrirMovimentacoes" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Solicitacoes de Acesso" onAction="#abrirUsuarios" maxWidth="Infinity" styleClass="nav-button"/>
            <VBox VBox.vgrow="ALWAYS"/>
            <Button text="Sair" onAction="#sair" maxWidth="Infinity" styleClass="danger-button"/>
        </VBox>
    </left>
    <center>
        <VBox spacing="20" styleClass="content">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Dashboard" styleClass="page-title"/>
                    <Label text="Visão operacional do estoque físico e movimentações recentes" styleClass="muted"/>
                </VBox>
                <Label text="Usuário:" styleClass="muted"/>
                <Label fx:id="usuarioLabel" styleClass="strong"/>
            </HBox>
            <GridPane hgap="16" vgap="16">
                <VBox GridPane.columnIndex="0" styleClass="metric-card">
                    <Label text="Total de produtos" styleClass="metric-label"/>
                    <Label fx:id="totalProdutosLabel" text="0" styleClass="metric-value"/>
                </VBox>
                <VBox GridPane.columnIndex="1" styleClass="metric-card">
                    <Label text="Quantidade em estoque" styleClass="metric-label"/>
                    <Label fx:id="quantidadeEstoqueLabel" text="0" styleClass="metric-value"/>
                </VBox>
                <VBox GridPane.columnIndex="2" styleClass="metric-card">
                    <Label text="Movimentações do dia" styleClass="metric-label"/>
                    <Label fx:id="movimentacoesHojeLabel" text="0" styleClass="metric-value"/>
                </VBox>
                <VBox GridPane.columnIndex="3" styleClass="metric-card">
                    <Label text="Sobras disponíveis" styleClass="metric-label"/>
                    <Label fx:id="sobrasDisponiveisLabel" text="0" styleClass="metric-value"/>
                </VBox>
            </GridPane>
            <HBox spacing="16" VBox.vgrow="ALWAYS">
                <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="panel">
                    <Label text="Fluxo de entradas e saídas" styleClass="section-title"/>
                    <BarChart fx:id="fluxoChart" animated="false" VBox.vgrow="ALWAYS">
                        <xAxis><CategoryAxis/></xAxis>
                        <yAxis><NumberAxis/></yAxis>
                    </BarChart>
                </VBox>
                <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="panel">
                    <Label text="Últimas movimentações" styleClass="section-title"/>
                    <TableView fx:id="ultimasTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="produtoColumn" text="Produto" prefWidth="120"/>
                            <TableColumn fx:id="tipoColumn" text="Tipo" prefWidth="150"/>
                            <TableColumn fx:id="quantidadeColumn" text="Qtd." prefWidth="70"/>
                            <TableColumn fx:id="dataColumn" text="Data" prefWidth="180"/>
                        </columns>
                    </TableView>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
