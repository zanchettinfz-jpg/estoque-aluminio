<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.UsuarioAdminController" styleClass="app-root">
    <left>
        <VBox prefWidth="240" spacing="8" styleClass="sidebar">
            <Label text="Estoque Aluminio" styleClass="sidebar-title"/>
            <Label text="Administracao" styleClass="sidebar-subtitle"/>
            <Button text="Dashboard" onAction="#abrirDashboard" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Produtos" onAction="#abrirProdutos" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Estoque" onAction="#abrirEstoque" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Sobras" onAction="#abrirSobras" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Movimentacoes" onAction="#abrirMovimentacoes" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Solicitacoes de Acesso" onAction="#abrirUsuarios" maxWidth="Infinity" styleClass="nav-button-active"/>
            <VBox VBox.vgrow="ALWAYS"/>
            <Button text="Sair" onAction="#sair" maxWidth="Infinity" styleClass="danger-button"/>
        </VBox>
    </left>
    <center>
        <VBox spacing="16" styleClass="content">
            <Label text="SOLICITACOES DE ACESSO" styleClass="page-title"/>
            <HBox spacing="16" VBox.vgrow="ALWAYS">
                <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="panel">
                    <TableView fx:id="usuariosTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="nomeColumn" text="Nome" prefWidth="260"/>
                            <TableColumn fx:id="loginColumn" text="Login" prefWidth="170"/>
                            <TableColumn fx:id="nivelColumn" text="Nivel" prefWidth="150"/>
                            <TableColumn fx:id="statusColumn" text="Status" prefWidth="140"/>
                            <TableColumn fx:id="criadoEmColumn" text="Criado em" prefWidth="210"/>
                        </columns>
                    </TableView>
                </VBox>
                <VBox spacing="12" prefWidth="320" styleClass="panel">
                    <Label text="Controle de acesso" styleClass="section-title"/>
                    <Label text="Nivel" styleClass="field-label"/>
                    <ComboBox fx:id="nivelCombo" maxWidth="Infinity"/>
                    <Label text="Status" styleClass="field-label"/>
                    <ComboBox fx:id="statusCombo" maxWidth="Infinity"/>
                    <Button text="Aprovar usuario" onAction="#aprovar" maxWidth="Infinity" styleClass="primary-button"/>
                    <Button text="Recusar usuario" onAction="#recusar" maxWidth="Infinity" styleClass="secondary-button"/>
                    <Button text="Bloquear usuario" onAction="#bloquear" maxWidth="Infinity" styleClass="danger-button"/>
                    <Button text="Salvar nivel/status" onAction="#salvarAlteracoes" maxWidth="Infinity" styleClass="secondary-button"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
